# =========================
# Feishu 回调服务（2B：本地服务 + 隧道）
# =========================
# 本地监听地址。通常保持默认即可。
FEISHU_CALLBACK_HOST="127.0.0.1"
# 本地监听端口。若被占用可改为其他端口（例如 8788）。
FEISHU_CALLBACK_PORT="8787"
# 回调 path。飞书后台 URL 需与此保持一致。
FEISHU_CALLBACK_PATH="/feishu/review-callback"

# =========================
# 回调鉴权
# =========================
# 推荐必填：回调 token。
# 飞书后台回调 URL 建议写成：
# https://<公网域名>/feishu/review-callback?token=<FEISHU_CALLBACK_AUTH_TOKEN>
# 生成方式示例：openssl rand -hex 16
FEISHU_CALLBACK_AUTH_TOKEN="replace-with-token"
# 可选：若飞书后台启用签名校验，则填入同一 secret。
# 未启用签名校验可留空。
FEISHU_SIGNING_SECRET=""

# =========================
# Feishu 自建应用（app-only）
# =========================
# 获取位置：飞书开放平台 -> 你的应用 -> 凭证与基础信息
FEISHU_APP_ID="cli_xxx"
# 获取位置：飞书开放平台 -> 你的应用 -> 凭证与基础信息
FEISHU_APP_SECRET="replace-with-app-secret"

# 审核群 chat_id（必填）
# 获取方式：
# 1) 先确保应用机器人已加入目标群
# 2) 执行：pnpm run feishu:chat:list
# 3) 从输出中复制对应 chat_id（oc_xxx）
REVIEW_CHAT_ID="oc_xxx"

# =========================
# 报告公网地址前缀（可选）
# =========================
# 用于把本地路径 outputs/... 转成飞书可点击链接 reviewUrl/publishedUrl。
# 你的仓库建议填写二选一：
# 1) GitHub 页面链接（推荐阅读体验）
#    https://github.com/tianyn1990/ai-weekly/blob/main
# 2) Raw 链接（纯文本）
#    https://raw.githubusercontent.com/tianyn1990/ai-weekly/main
# 注意：不要填写 tree/outputs 路径，否则会拼接出重复的 outputs。
REPORT_PUBLIC_BASE_URL=""
