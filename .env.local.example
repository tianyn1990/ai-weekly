# =========================
# Feishu 回调服务（2B：本地服务 + 隧道）
# =========================
# 本地监听地址。通常保持默认即可。
FEISHU_CALLBACK_HOST="127.0.0.1"
# 本地监听端口。若被占用可改为其他端口（例如 8788）。
FEISHU_CALLBACK_PORT="8787"
# 回调 path。飞书后台 URL 需与此保持一致。
FEISHU_CALLBACK_PATH="/feishu/review-callback"

# =========================
# 回调鉴权
# =========================
# 推荐必填：回调 token。
# 飞书后台回调 URL 建议写成：
# https://<公网域名>/feishu/review-callback?token=<FEISHU_CALLBACK_AUTH_TOKEN>
# 生成方式示例：openssl rand -hex 16
FEISHU_CALLBACK_AUTH_TOKEN="replace-with-token"
# 可选：若飞书后台启用签名校验，则填入同一 secret。
# 未启用签名校验可留空。
FEISHU_SIGNING_SECRET=""

# =========================
# Feishu 自建应用（app-only）
# =========================
# 获取位置：飞书开放平台 -> 你的应用 -> 凭证与基础信息
FEISHU_APP_ID="cli_xxx"
# 获取位置：飞书开放平台 -> 你的应用 -> 凭证与基础信息
FEISHU_APP_SECRET="replace-with-app-secret"

# 审核群 chat_id（必填）
# 获取方式：
# 1) 先确保应用机器人已加入目标群
# 2) 执行：pnpm run feishu:chat:list
# 3) 从输出中复制对应 chat_id（oc_xxx）
REVIEW_CHAT_ID="oc_xxx"

# =========================
# 报告公网地址前缀（可选）
# =========================
# 用于把本地路径 outputs/... 转成飞书可点击链接 reviewUrl/publishedUrl。
# 你的仓库建议填写二选一：
# 1) GitHub 页面链接（推荐阅读体验）
#    https://github.com/tianyn1990/ai-weekly/blob/main
# 2) Raw 链接（纯文本）
#    https://raw.githubusercontent.com/tianyn1990/ai-weekly/main
# 注意：不要填写 tree/outputs 路径，否则会拼接出重复的 outputs。
REPORT_PUBLIC_BASE_URL=""

# =========================
# LLM 增强（M5.3，MiniMax）
# =========================
# true: 启用逐条 LLM 总结 + 3 分钟速览 + 辅助排序/打标 + 导语与标题翻译。
LLM_SUMMARY_ENABLED="false"
# 当前仅支持 minimax（保留 provider 抽象便于后续扩展）。
LLM_SUMMARY_PROVIDER="minimax"
# MiniMax API Key（必填后才会走真实模型调用）。
MINIMAX_API_KEY=""
# Anthropic 兼容命名（可与 MINIMAX_API_KEY 二选一，便于直接复用官方示例）。
ANTHROPIC_API_KEY=""
# MiniMax 模型名，默认 MiniMax-M2.5。
MINIMAX_MODEL="MiniMax-M2.5"
# 单次模型请求超时（毫秒）。
LLM_SUMMARY_TIMEOUT_MS="60000"
# 参与逐条总结的最大候选数（按 rankedItems 前 N 条）。
LLM_SUMMARY_MAX_ITEMS="30"
# 单节点并发度（会被全局并发上限再裁剪，当前建议 2）。
LLM_SUMMARY_MAX_CONCURRENCY="2"
# 全局 LLM 并发上限（当前推荐 2，优先稳定性）。
LLM_GLOBAL_MAX_CONCURRENCY="2"
# 规则分与 LLM 分融合权重（0-1，越大越偏向 LLM）。
LLM_RANK_FUSION_WEIGHT="0.65"
# LLM 最低置信度门槛（低于该值自动回退规则分）。
LLM_ASSIST_MIN_CONFIDENCE="0.5"
# Prompt 版本号（用于审计追踪与回放；M5.3 默认包含自适应降载与分类导读策略）。
LLM_SUMMARY_PROMPT_VERSION="m5.3-v1"
# true: 当本次 run 发生 LLM 回退时，飞书发送 1 条合并告警；false: 不告警。
LLM_FALLBACK_ALERT_ENABLED="true"
# 可选：Anthropic 兼容 Base URL（Coding Plan 推荐）。
ANTHROPIC_BASE_URL="https://api.minimaxi.com/anthropic"
# 可选：历史字段兼容，未设置 ANTHROPIC_BASE_URL 时会回退读取该值。
# MINIMAX_API_BASE_URL=""

# =========================
# Daemon 常驻运行（M4.3）
# =========================
# 可选：service-ops 使用的环境文件路径。默认读取项目根目录 .env.local。
# AI_WEEKLY_ENV_FILE="/Users/<your-user>/Documents/github/ai-weekly/.env.local"
# 可选：launchd 专用 env 文件路径。默认 ~/.config/ai-weekly/.env.launchd
# 说明：service-ops 会把 AI_WEEKLY_ENV_FILE 同步到此路径，避免 macOS 对 Documents/Desktop 的读取限制。
# 重要：不要把 AI_WEEKLY_ENV_FILE 直接指向 AI_WEEKLY_LAUNCHD_ENV_FILE，否则会导致“源/目标同文件”并引发配置漂移。
# AI_WEEKLY_LAUNCHD_ENV_FILE="/Users/<your-user>/.config/ai-weekly/.env.launchd"

# 启用后可使用 `pnpm run run:daemon` 持续调度 daily/weekly/reminder/watchdog。
DAEMON_SCHEDULER_INTERVAL_MS="30000"
DAEMON_WORKER_POLL_MS="2000"
# 调度触发 marker 存储目录（用于补偿扫描与去重）。
DAEMON_MARKER_ROOT="outputs/daemon/schedule-markers"

# =========================
# Named Tunnel（长期稳定模式，推荐）
# =========================
# 固定 tunnel 名称（用于 `cloudflared tunnel run <name>`）。
CLOUDFLARED_TUNNEL_NAME="ai-weekly-callback"
# 本机 cloudflared config 位置（setup:macos/up/status 会读取该文件）。
CLOUDFLARED_CONFIG_PATH="/Users/<your-user>/.cloudflared/config.yml"
# 首次 setup 自动生成 config 时使用（若 config 已存在可留空）。
CLOUDFLARED_TUNNEL_ID=""
# 首次 setup 自动生成 config 时使用（若 config 已存在可留空）。
CLOUDFLARED_TUNNEL_HOSTNAME="callback.example.com"
# 可选：credentials-file 绝对路径；不填时默认按 tunnel id 推导。
CLOUDFLARED_CREDENTIALS_FILE=""
# 可选：services:logs 默认 tail 行数。
SERVICE_LOGS_TAIL="80"

# =========================
# 自动 Git 同步（可选）
# =========================
# true: 每次产物写入后自动 add/commit/push；false: 不自动同步。
AUTO_GIT_SYNC="false"
# true: 执行 push；false: 仅 commit 不 push（便于本地验证）。
GIT_SYNC_PUSH="false"
# 受控同步路径（逗号分隔）。建议保留以下默认值。
GIT_SYNC_INCLUDE_PATHS="outputs/review,outputs/published,outputs/review-instructions,outputs/runtime-config"
GIT_SYNC_REMOTE="origin"
# 可选：固定推送分支，不填则推送到当前 HEAD 对应远端分支。
GIT_SYNC_BRANCH=""

# =========================
# Git push 代理（可选）
# =========================
# 某些网络环境下 push 需要代理，可在此配置（仅 push 命令使用，不影响其他命令）。
# 示例：
# GIT_PUSH_HTTP_PROXY="http://127.0.0.1:8118"
# GIT_PUSH_HTTPS_PROXY="http://127.0.0.1:8118"
# GIT_PUSH_NO_PROXY="localhost,127.0.0.1"
GIT_PUSH_HTTP_PROXY=""
GIT_PUSH_HTTPS_PROXY=""
GIT_PUSH_NO_PROXY=""
