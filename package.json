{
  "name": "ai-weekly",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "基于 LangGraph 的 AI 日报/周报自动化骨架",
  "scripts": {
    "run:daily:mock": "tsx src/cli.ts run --mode daily --mock",
    "run:weekly:mock": "tsx src/cli.ts run --mode weekly --mock",
    "run:weekly:watch": "tsx src/cli.ts run --mode weekly --watch-pending-weekly",
    "run:daily": "tsx src/cli.ts run --mode daily",
    "run:weekly": "tsx src/cli.ts run --mode weekly",
    "run:review:api": "tsx src/cli.ts run --serve-review-api",
    "run:migrate:file-to-db": "tsx src/cli.ts run --migrate-file-to-db --storage-backend db",
    "verify:m4": "bash scripts/m4-verify.sh",
    "db:open": "bash scripts/db-open.sh",
    "db:sqlite": "sqlite3 outputs/db/app.sqlite",
    "feishu:callback": "tsx src/cli.ts run --serve-feishu-callback",
    "feishu:tunnel": "bash scripts/feishu-tunnel.sh",
    "feishu:dev": "bash scripts/feishu-dev.sh",
    "feishu:fullflow": "bash scripts/feishu-fullflow.sh",
    "feishu:token": "tsx src/tools/feishu-ops.ts token",
    "feishu:chat:list": "tsx src/tools/feishu-ops.ts chats",
    "feishu:card:send": "tsx src/tools/feishu-ops.ts send-card",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@langchain/langgraph": "^0.4.0",
    "dayjs": "^1.11.13",
    "rss-parser": "^3.13.0",
    "sql.js": "^1.14.1",
    "yaml": "^2.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/sql.js": "^1.4.9",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
