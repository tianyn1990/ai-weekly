{
  "name": "ai-weekly",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "基于 LangGraph 的 AI 日报/周报自动化骨架",
  "scripts": {
    "run:daily:mock": "tsx src/cli.ts run --mode daily --mock",
    "run:weekly:mock": "tsx src/cli.ts run --mode weekly --mock",
    "run:daily": "tsx src/cli.ts run --mode daily",
    "run:weekly": "tsx src/cli.ts run --mode weekly",
    "build": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@langchain/langgraph": "^0.4.0",
    "dayjs": "^1.11.13",
    "rss-parser": "^3.13.0",
    "yaml": "^2.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
